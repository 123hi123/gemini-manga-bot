# Gemini API Key（可選；也可啟動後用 /service add 新增）
GEMINI_API_KEY=your_gemini_api_key_here

# Gemini Base URL（可選，自訂代理時可設定）
GEMINI_BASE_URL=

# Gemini Model（可選，預設 gemini-3-pro-image-preview）
GEMINI_MODEL=

# Telegram Bot Token
BOT_TOKEN=your_telegram_bot_token_here

# Grok API Key（可選，啟用 Grok 圖片/影片生成）
GROK_API_KEY=

# Grok Base URL（預設 http://127.0.0.1:8000）
GROK_BASE_URL=

# Grok 圖片生成模型（預設 grok-imagine-1.0）
GROK_IMG_MODEL=

# Grok 圖片編輯模型（預設 grok-imagine-1.0-edit）
GROK_EDIT_MODEL=

# Grok 影片生成模型（預設 grok-imagine-1.0-video）
GROK_VIDEO_MODEL=
